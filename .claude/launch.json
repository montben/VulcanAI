{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "backend/.venv/bin/python3",
      "runtimeArgs": ["-m", "backend.app"],
      "port": 8000,
      "autoPort": true
    },
    {
      "name": "frontend",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "--directory", "frontend"],
      "port": 3000,
      "autoPort": true
    }
  ]
}
