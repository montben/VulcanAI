# ============================================
# SiteScribe AI — Backend Environment Config
# ============================================
# Add at least one API key. Groq is recommended (free tier).
# Get a free Groq key at: https://console.groq.com
# ============================================

# Recommended — free, fast, no credit card needed
GROQ_API_KEY=gsk_your_key_here

# Voice transcription (Deepgram)
# Get a free key at: https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_key_here

# Alternative providers (optional):
# GOOGLE_API_KEY=AIza...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional model overrides (defaults shown):
# VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# SYNTHESIS_MODEL=llama-3.3-70b-versatile
# MAX_PHOTO_DIMENSION=2048

# Backend runtime settings
API_HOST=0.0.0.0
API_PORT=8000

# Database (matches docker-compose defaults)
DATABASE_URL=postgresql://vulcan:vulcan_dev@localhost:5432/vulcan

# Photo upload directory
UPLOAD_DIR=./uploads

# Frontend origins allowed by CORS
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:4173,http://localhost:5173
